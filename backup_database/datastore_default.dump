--
-- Name: cached_table_row_count(name); Type: FUNCTION; Schema: public; Owner: ckan_default
--

CREATE FUNCTION public.cached_table_row_count(table_name name) RETURNS bigint
    LANGUAGE plpgsql
    AS $$
    DECLARE
        row_count BIGINT;
    BEGIN
        SELECT stats -> 'rows' INTO row_count FROM "_table_stats"
            WHERE "resource_id" = table_name;
        IF row_count IS NULL THEN
            SELECT update_cached_table_row_count(table_name) INTO row_count;
        END IF;
        RETURN row_count;
    END;
$$;


ALTER FUNCTION public.cached_table_row_count(table_name name) OWNER TO ckan_default;

--
-- Name: populate_full_text_trigger(); Type: FUNCTION; Schema: public; Owner: ckan_default
--

CREATE FUNCTION public.populate_full_text_trigger() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
    BEGIN
        IF NEW._full_text IS NOT NULL THEN
            RETURN NEW;
        END IF;
        NEW._full_text := (
            SELECT to_tsvector(string_agg(value, ' '))
            FROM json_each_text(row_to_json(NEW.*))
            WHERE key NOT LIKE '\_%');
        RETURN NEW;
    END;
$$;


ALTER FUNCTION public.populate_full_text_trigger() OWNER TO ckan_default;

--
-- Name: update_cached_table_row_count(name); Type: FUNCTION; Schema: public; Owner: ckan_default
--

CREATE FUNCTION public.update_cached_table_row_count(table_name name) RETURNS bigint
    LANGUAGE plpgsql
    AS $$
    DECLARE
        row_count BIGINT;
    BEGIN
        EXECUTE format('SELECT count(*) FROM public.%I', table_name)
            INTO row_count;
        INSERT INTO "_table_stats"
            VALUES (table_name, jsonb_build_object('rows', row_count))
            ON CONFLICT ("resource_id") DO UPDATE SET "stats" =
                jsonb_set("_table_stats"."stats", array['rows'], to_jsonb(row_count));
        RETURN row_count;
    END;
$$;


ALTER FUNCTION public.update_cached_table_row_count(table_name name) OWNER TO ckan_default;

--
-- Name: update_table_stats(name); Type: FUNCTION; Schema: public; Owner: ckan_default
--

CREATE FUNCTION public.update_table_stats(table_name name) RETURNS boolean
    LANGUAGE plpgsql
    AS $$
    BEGIN
        EXECUTE format('ANALYZE public.%I', table_name);
        PERFORM cached_table_row_count(table_name);
        RETURN TRUE;
    END;
$$;


ALTER FUNCTION public.update_table_stats(table_name name) OWNER TO ckan_default;

